# ==========================================
# STEP 1: INITIAL SERVER ACCESS & PREP
# ==========================================
# Log into your Quasar VPS (find credentials in Namecheap email)
ssh root@your_vps_ip

# Update system packages
sudo apt update && sudo apt upgrade -y

# Install LEMP Stack (Nginx, MySQL, PHP 8.x)
sudo apt install nginx mariadb-server php-fpm php-mysql php-xml php-curl php-mbstring php-zip -y

# ==========================================
# STEP 2: DOMAIN & DNS CONFIGURATION
# ==========================================
# 1. Log into Namecheap Dashboard -> Domain List -> Manage.
# 2. Go to 'Advanced DNS' tab.
# 3. Add 'A Record': Host=@, IP=your_vps_ip.
# 4. Add 'A Record': Host=www, IP=your_vps_ip.
# 5. Wait for propagation (usually 10-30 minutes).

# ==========================================
# STEP 3: LARAVEL DEPLOYMENT
# ==========================================
# Navigate to web root and clone your repo
cd /var/www
git clone https://github.com
cd yourproject

# Install PHP dependencies
composer install --no-dev --optimize-autoloader

# Set permissions (Critical for Laravel to work)
sudo chown -R www-data:www-data storage bootstrap/cache
sudo chmod -R 775 storage bootstrap/cache

# Setup environment variables
cp .env.example .env
nano .env  # Update your DB_DATABASE, DB_USERNAME, and DB_PASSWORD
php artisan key:generate
php artisan migrate --force

# ==========================================
# STEP 4: QUASAR INTEGRATION (Frontend)
# ==========================================
# OPTION A: Monolith (Quasar inside Laravel)
# Run locally first: 'quasar build'
# Then upload/move 'dist/spa' contents to Laravel's '/public' folder

# OPTION B: Separate Frontend (Recommended for HMR)
# Ensure Node.js is installed on VPS
sudo apt install nodejs npm -y
npm install -g @quasar/cli
npm install && quasar build

# ==========================================
# STEP 5: NGINX CONFIGURATION
# ==========================================
# Create a new site config
sudo nano /etc/nginx/sites-available/yourdomain.com

# [PASTE TEMPLATE BELOW INTO FILE]
# server {
#     listen 80;
#     server_name yourdomain.com ://yourdomain.com;
#     root /var/www/yourproject/public;
#     index index.php index.html;
#
#     location / {
#         try_files $uri $uri/ /index.php?$query_string;
#     }
#
#     location ~ \.php$ {
#         include snippets/fastcgi-php.conf;
#         fastcgi_pass unix:/var/run/php/php8.x-fpm.sock; # Adjust PHP version
#     }
# }

# Enable the site and restart Nginx
sudo ln -s /etc/nginx/sites-available/yourdomain.com /etc/nginx/sites-enabled/
sudo nginx -t && sudo systemctl restart nginx







                    ###########  AFTER SYNCING RITUAL ###########






# 1. Change ownership of the entire project to the web user
sudo chown -R www-data:www-data /var/www/taongaf

# 2. Set the correct permissions for storage and cache folders
sudo chmod -R 775 /var/www/taongaf/storage
sudo chmod -R 775 /var/www/taongaf/bootstrap/cache

# 3. Clear Laravel's internal caches to start fresh
cd /var/www/taongaf
php artisan config:clear
php artisan cache:clear
php artisan view:clear








